{
  "expo": {
    "name": "LunchPad",
    "slug": "lunchpad",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "us.lunchpad.app",
      "buildNumber": "13",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "us.lunchpad.app"
    },
    "scheme": "lunchpad",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-apple-authentication",
        {}
      ],
      "expo-asset",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1b47df76-dfdf-41ed-934b-6017f2ae6e81"
      }
    },
    "owner": "getlunchpad"
  }
}
